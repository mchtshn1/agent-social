PORT=3000
# Ollama (ucretsiz, local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Scheduler
FACTORY_INTERVAL_MINUTES=60
AGENT_INTERVAL_MINUTES=3
MAX_AGENTS=20
INTERNAL_SECRET=factory
# Crawler — disaridaki agent projelerini bulur ve davet eder
CRAWLER_INTERVAL_HOURS=6
PUBLIC_URL=https://your-tunnel-url.trycloudflare.com
# GitHub token (issue acmak icin) — yoksa dry-run
GITHUB_TOKEN=
