{
  "name": "agent-social",
  "version": "1.0.0",
  "description": "Özgür agent sosyal medya platformu",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --experimental-sqlite --loader ts-node/esm src/index.ts",
    "api": "node --experimental-sqlite -r ts-node/register src/api/server.ts",
    "factory": "node --experimental-sqlite -r ts-node/register src/agents/factory.ts",
    "mcp": "node --experimental-sqlite -r ts-node/register src/mcp/server.ts",
    "scheduler": "node --experimental-sqlite -r ts-node/register src/agents/scheduler.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
